# Reportes por audio (Faster-Whisper local)
# small: balance recomendado, medium: mas precision, tiny/base: mas rapido
REPORTS_STT_MODEL=small
# cpu para servidores sin GPU; cuda si tienes GPU NVIDIA disponible
REPORTS_STT_DEVICE=cpu
# int8 recomendado en CPU; float16 para GPU compatible
REPORTS_STT_COMPUTE_TYPE=int8
# true para imprimir la transcripcion completa en logs del backend durante depuracion
REPORTS_AUDIO_DEBUG=False

